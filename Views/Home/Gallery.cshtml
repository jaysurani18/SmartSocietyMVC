@{
    ViewData["Title"] = "Gallery";
}

<div class="relative bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&q=80')] bg-cover bg-center opacity-10 mix-blend-overlay"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight">
            Society <span class="text-blue-400">Gallery</span>
        </h1>
        <p class="text-xl text-slate-300 max-w-2xl mx-auto">
            Experience the vibrant lifestyle and premium amenities of SmartSociety.
        </p>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Park -->
        <div class="group relative rounded-2xl overflow-hidden shadow-xl aspect-video cursor-pointer">
            <img src="~/images/gallery/park.png" alt="Community Park" class="w-full h-full object-cover transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent opacity-80 group-hover:opacity-100 transition duration-300 flex items-end">
                <div class="p-6">
                    <h3 class="text-2xl font-bold text-white">Lush Green Parks</h3>
                    <p class="text-slate-200 mt-2">Peaceful walking tracks and play areas for a healthy community lifestyle.</p>
                </div>
            </div>
        </div>

        <!-- Clubhouse -->
        <div class="group relative rounded-2xl overflow-hidden shadow-xl aspect-video cursor-pointer">
            <img src="~/images/gallery/clubhouse.png" alt="Grand Clubhouse" class="w-full h-full object-cover transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent opacity-80 group-hover:opacity-100 transition duration-300 flex items-end">
                <div class="p-6">
                    <h3 class="text-2xl font-bold text-white">Grand Clubhouse</h3>
                    <p class="text-slate-200 mt-2">The center of our community activities, events, and gatherings.</p>
                </div>
            </div>
        </div>

        <!-- Pool -->
        <div class="group relative rounded-2xl overflow-hidden shadow-xl aspect-video cursor-pointer">
            <img src="~/images/gallery/pool.png" alt="Swimming Pool" class="w-full h-full object-cover transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent opacity-80 group-hover:opacity-100 transition duration-300 flex items-end">
                <div class="p-6">
                    <h3 class="text-2xl font-bold text-white">Olympic Size Pool</h3>
                    <p class="text-slate-200 mt-2">Luxurious swimming pool with dedicated kids area and loungers.</p>
                </div>
            </div>
        </div>

        <!-- Gym -->
        <div class="group relative rounded-2xl overflow-hidden shadow-xl aspect-video cursor-pointer">
            <img src="~/images/gallery/gym.png" alt="Modern Gymnasium" class="w-full h-full object-cover transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent opacity-80 group-hover:opacity-100 transition duration-300 flex items-end">
                <div class="p-6">
                    <h3 class="text-2xl font-bold text-white">Modern Gymnasium</h3>
                    <p class="text-slate-200 mt-2">Fully equipped fitness center to keep our residents fit and healthy.</p>
                </div>
            </div>
        </div>
    </div>
</div>
